# ─── API Keys ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# All keys are for FREE tiers — no paid plans required.
# Restart the dev server after editing this file.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — visible in: Supabase dashboard → Settings → API
SUPABASE_URL=

# ⚠ Server-side only. Never expose to the browser or commit to git.
# Found in: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Public anon key — safe to expose to the browser (used in Phase 2 frontend client)
# Found in: Supabase dashboard → Settings → API → anon / public key
SUPABASE_ANON_KEY=

# VITE_ prefixed versions — exposed to the browser bundle via Vite
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Finnhub — https://finnhub.io (60 calls/min)
VITE_FINNHUB_KEY=

# Alpha Vantage — https://www.alphavantage.co/support/#api-key (25 calls/day)
VITE_ALPHAVANTAGE_KEY=

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html (unlimited)
VITE_FRED_KEY=

# Financial Modeling Prep — https://financialmodelingprep.com/developer (250 calls/day)
VITE_FMP_KEY=

# CoinGecko — no key required on free tier

# BRAPI — https://brapi.dev (Brazilian B3 equities)
VITE_BRAPI_TOKEN=

# BCB (Banco Central do Brasil) — no key required
# AwesomeAPI (FX rates) — no key required

# Production backend URL (leave empty in development — Vite proxy handles routing)
# Example: https://global-markets-terminal.up.railway.app
VITE_API_URL=
