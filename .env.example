# ─── API Keys ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# All keys are for FREE tiers — no paid plans required.
# Restart the dev server after editing this file.

# Finnhub — https://finnhub.io (60 calls/min)
VITE_FINNHUB_KEY=

# Alpha Vantage — https://www.alphavantage.co/support/#api-key (25 calls/day)
VITE_ALPHAVANTAGE_KEY=

# FRED — https://fred.stlouisfed.org/docs/api/api_key.html (unlimited)
VITE_FRED_KEY=

# Financial Modeling Prep — https://financialmodelingprep.com/developer (250 calls/day)
VITE_FMP_KEY=

# CoinGecko — no key required on free tier

# BRAPI — https://brapi.dev (Brazilian B3 equities)
VITE_BRAPI_TOKEN=

# BCB (Banco Central do Brasil) — no key required
# AwesomeAPI (FX rates) — no key required
