# ─── Production environment variables ───────────────────────────────────────
# Set these in Railway's environment variable dashboard.
# Never commit real values to the repository.

# Required
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars
NODE_ENV=production

# Supabase (from your Supabase project settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-not-the-anon-key

# CORS — comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=https://your-app.pages.dev,https://yourdomain.com

# API keys (these are VITE_ prefixed — also set them in Cloudflare Pages build vars)
VITE_FINNHUB_KEY=
VITE_FMP_KEY=
VITE_FRED_KEY=
VITE_BRAPI_TOKEN=
VITE_ALPHA_VANTAGE_KEY=

# Port — Railway sets this automatically, do not override
# PORT=4000
