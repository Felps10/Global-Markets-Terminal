{
  "name": "markets-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --max-http-header-size=65536 proxy-server.js",
    "start:server": "node server/index.js",
    "start": "node --max-http-header-size=65536 server/index.js",
    "start:dev": "concurrently -n proxy,vite -c cyan,green \"npm run server\" \"npm run dev\"",
    "start:full": "concurrently -n proxy,api,vite -c cyan,magenta,green \"npm run server\" \"npm run start:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node --input-type=module --eval \"import('./server/seed.js').then(async m => { await m.seedIfEmpty(); m.logTaxonomyCounts(); })\"",
    "test": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "lightweight-charts": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "jsdom": "^28.1.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
