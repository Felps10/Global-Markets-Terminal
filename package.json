{
  "name": "markets-dashboard",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:server": "node --max-http-header-size=65536 server/index.js",
    "start": "node --max-http-header-size=65536 server/index.js",
    "start:dev": "concurrently -n api,vite -c magenta,green \"npm run start:server\" \"npm run dev\"",
    "start:full": "concurrently -n proxy,api,vite -c yellow,magenta,green \"node --max-http-header-size=65536 proxy-server.js\" \"npm run start:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "seed": "node --input-type=module --eval \"import('./server/seed.js').then(async m => { await m.seedIfEmpty(); await m.logTaxonomyCounts(); })\"",
    "test": "vitest",
    "snapshot": "node scripts/captureSnapshot.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/react-virtual": "^3.13.23",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "lightweight-charts": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.0",
    "react-router-dom": "^6.28.0",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-styled-components": "^2.1.4",
    "concurrently": "^9.0.0",
    "jsdom": "^28.1.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
